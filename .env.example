# --- LLM Provider Configuration ---
# Options: 
# - https://api.openai.com/v1
# - https://models.inference.ai.azure.com (GitHub Models)
# - https://api.groq.com/openai/v1
# - https://api.deepseek.com

API_BASE_URL=https://models.inference.ai.azure.com

# Your API Key (ghp_..., sk-..., or gsk_...)
API_KEY=your_api_key_here

# The model identifier (gpt-4o, gpt-4o-mini, o1-mini, llama-3.3-70b-versatile, deepseek-chat)
MODEL_NAME=gpt-4o-mini

# --- Agent Hyperparameters ---
MAX_STEPS=30
MAX_TOKENS=500
TEMPERATURE=0.0
